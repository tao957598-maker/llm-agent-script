```json
{
  "platform": "FPS Payment System",
  "modules": [
    {
      "name": "Inbound Transfer Flow",
      "source": "Page1",
      "submodules": [
        {
          "name": "Transfer Initiation - Counter/Online/Mobile Banking",
          "description": "Payer initiates a transfer via counter, online banking, or mobile banking. Supports FPS ID, mobile number, email, or account number as recipient identifier.",
          "source": "Page1"
        },
        {
          "name": "Account Verification and Debit Check - FPS and Deposit System",
          "description": "FPS calls the deposit system to perform account verification, limit check, and debit. If verification or debit fails, the transaction is rejected.",
          "source": "Page1"
        },
        {
          "name": "Transaction Transmission to HKICL - pacs.008",
          "description": "Payer bank transmits the transaction instruction to HKICL in FIToFICustomerCreditTransfer (pacs.008) format.",
          "source": "Page1"
        },
        {
          "name": "Transaction Forwarding to Beneficiary Bank - pacs.008",
          "description": "HKICL forwards the transaction to the beneficiary bank in pacs.008 format. If the beneficiary bank is in real-time mode, account verification is performed.",
          "source": "Page1"
        }
      ]
    },
    {
      "name": "FPS Payment Flow - Real-time Mode",
      "source": "Page2",
      "submodules": [
        {
          "name": "Account Verification Result Response - Beneficiary Bank to HKICL",
          "description": "Beneficiary bank (in real-time mode) replies to HKICL with account verification result using pacs.002 (FIToFIPmtStsRpt) format.",
          "source": "Page2"
        },
        {
          "name": "Settlement Execution - HKICL FPS Platform",
          "description": "HKICL FPS platform executes settlement after receiving the account verification result from the beneficiary bank.",
          "source": "Page2"
        },
        {
          "name": "Settlement Result Notification to Payer Bank - pacs.002 (Step 5a)",
          "description": "Payer bank receives settlement result from HKICL via pacs.002 message and notifies the payer of the transfer result.",
          "source": "Page2"
        },
        {
          "name": "Settlement Result Notification to Beneficiary Bank - pacs.002 (Step 5b)",
          "description": "Beneficiary bank receives settlement result from HKICL via pacs.002 message.",
          "source": "Page2"
        },
        {
          "name": "Credit Notification to Payer",
          "description": "System informs the payer of the credit result to the beneficiary account.",
          "source": "Page2"
        }
      ]
    },
    {
      "name": "Message Type Reference",
      "source": "Page2",
      "submodules": [
        {
          "name": "Message Type Layout Reference Table",
          "description": "Reference table listing message types (pacs.008 Credit Transfer, pacs.008 Account Verification, pacs.002 Account Verification Result, pacs.002 Payment Status Report) with their corresponding layout sections and scenarios (Real-time/Batch).",
          "source": "Page2"
        }
      ]
    }
  ]
}
```
